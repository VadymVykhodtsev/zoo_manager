<%= form_with(model: animal, class: "contents") do |form| %>
  <% if animal.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(animal.errors.count, "error") %> prohibited this animal from being saved:</h2>

      <ul class="list-disc ml-6">
        <% animal.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :species %>
    <%= form.text_field :species, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": animal.errors[:species].none?, "border-red-400 focus:outline-red-600": animal.errors[:species].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :age %>
    <%= form.number_field :age, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": animal.errors[:age].none?, "border-red-400 focus:outline-red-600": animal.errors[:age].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :sex %>
    <%= form.text_field :sex, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": animal.errors[:sex].none?, "border-red-400 focus:outline-red-600": animal.errors[:sex].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
